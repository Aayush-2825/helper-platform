{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "PORT",
    "DATABASE_URL",
    "DATABASE_URL_WEB",
    "DATABASE_URL_REALTIME",
    "REDIS_URL",
    "CORS_ORIGIN",
    "NODE_ENV",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "NEXT_PUBLIC_BETTER_AUTH_URL",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "FROM_EMAIL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "RAZORPAY_KEY_ID",
    "RAZORPAY_KEY_SECRET",
    "RAZORPAY_WEBHOOK_SECRET",
    "REALTIME_BROADCAST_SECRET",
    "REALTIME_WS_AUTH_SECRET",
    "REALTIME_BASE_URL",
    "NEXT_PUBLIC_REALTIME_HTTP_BASE_URL",
    "NEXT_PUBLIC_REALTIME_WS_URL",
    "NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY",
    "WEB_PUSH_VAPID_PRIVATE_KEY",
    "WEB_PUSH_CONTACT_EMAIL",
    "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME",
    "NEXT_PUBLIC_CLOUDINARY_PRESET",
    "CLOUDINARY_CLOUD_NAME",
    "CLOUDINARY_API_KEY",
    "CLOUDINARY_API_SECRET",
    "ENCRYPTION_KEY",
    "AUTH_SECRET",
    "CRON_SECRET",
    "GOOGLE_SERVICE_ACCOUNT_JSON",
    "GOOGLE_KYC_CALENDAR_ID",
    "KYC_ADMIN_EMAIL",
    "EMAIL_PROVIDER_API_KEY"
    
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "PORT",
        "DATABASE_URL",
        "DATABASE_URL_WEB",
        "DATABASE_URL_REALTIME",
        "REDIS_URL",
        "CORS_ORIGIN",
        "NODE_ENV"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "env": [
        "PORT",
        "DATABASE_URL",
        "DATABASE_URL_WEB",
        "DATABASE_URL_REALTIME",
        "REDIS_URL",
        "CORS_ORIGIN",
        "NODE_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "env": [
        "PORT",
        "DATABASE_URL",
        "DATABASE_URL_WEB",
        "DATABASE_URL_REALTIME",
        "REDIS_URL",
        "CORS_ORIGIN",
        "NODE_ENV"
      ],
      "persistent": true
    }
  }
}
