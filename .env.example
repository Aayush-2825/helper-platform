# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/helper_platform"
DATABASE_URL_WEB="postgresql://user:password@localhost:5432/helper_platform_web"
DATABASE_URL_REALTIME="postgresql://user:password@localhost:5432/helper_platform_realtime"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# Server Port
PORT=3000
REALTIME_PORT=3001
CORS_ORIGIN="http://localhost:3000"

# Realtime Service Endpoints
REALTIME_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_REALTIME_HTTP_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_REALTIME_WS_URL="ws://localhost:3001/api/realtime/ws"

# Node Environment
NODE_ENV=development

# Authentication (OAuth Providers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email Configuration (for password reset, verification)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# API Keys & Secrets
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Production template note
# Keep real production secrets out of version control.

# Upload Configuration
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_PRESET=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Feature Flags
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR=false

# Helper onboarding + KYC workflow
GOOGLE_KYC_CALENDAR_ID="" # Optional: Specific calendar ID for KYC. Defaults to admin's primary calendar.
VIDEO_KYC_FALLBACK_MEETING_BASE_URL="https://meet.jit.si"  # Optional fallback if Google returns event without conference details
KYC_ADMIN_EMAIL=""
KYC_ADMIN_CALENDAR_MAP=''
VIDEO_KYC_HOST_EMAIL="" # Optional attendee/host email (defaults to first key in KYC_ADMIN_CALENDAR_MAP)
VIDEO_KYC_TIMEZONE="Asia/Kolkata"
VIDEO_KYC_TIMEZONE_OFFSET="+05:30"
VIDEO_KYC_START_HOUR_LOCAL=10
VIDEO_KYC_END_HOUR_LOCAL=18
VIDEO_KYC_SLOT_INTERVAL_MINUTES=15
VIDEO_KYC_DURATION_MINUTES=20
VIDEO_KYC_MIN_LEAD_MINUTES=60
VIDEO_KYC_DAYS_AHEAD=7
VIDEO_KYC_JOIN_NOT_BEFORE_MINUTES=10
VIDEO_KYC_JOIN_NOT_AFTER_MINUTES=15
EMAIL_PROVIDER_API_KEY=""
PUSH_PROVIDER_API_KEY=""
CRON_SECRET=""
