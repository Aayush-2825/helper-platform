# Production Environment Variables Template
NODE_ENV=production
PORT=3000
REALTIME_PORT=3001

# Database Configuration (set these values)
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://your_db_user:your_db_password@postgres:5432/helper_platform
DATABASE_URL_WEB=postgresql://your_db_user:your_db_password@postgres:5432/helper_platform_web
DATABASE_URL_REALTIME=postgresql://your_db_user:your_db_password@postgres:5432/helper_platform_realtime

# Redis Configuration (set password)
REDIS_URL=redis://:your_redis_password@redis:6379
REDIS_PASSWORD=your_redis_password

# CORS - Update with your production domain
CORS_ORIGIN=https://your-domain.com

# Realtime Service - Update with your production URLs
REALTIME_BASE_URL=https://your-domain.com
NEXT_PUBLIC_REALTIME_HTTP_BASE_URL=https://your-domain.com
NEXT_PUBLIC_REALTIME_WS_URL=wss://your-domain.com/api/realtime/ws

# Authentication - Generate a secure secret
BETTER_AUTH_SECRET=your-secure-random-secret-here
BETTER_AUTH_URL=https://your-domain.com

# OAuth Providers (set your actual credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email Service (set your Resend API key)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@your-domain.com

# Payment Gateway (set your Razorpay credentials)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Cloud Storage (set your Cloudinary credentials)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_name
NEXT_PUBLIC_CLOUDINARY_PRESET=your_preset
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
