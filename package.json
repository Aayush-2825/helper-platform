{
  "name": "helper-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "db:sync:realtime": "pnpm --filter @repo/db sync:realtime",
    "db:verify:realtime": "pnpm --filter @repo/db verify:realtime",
    "db:push:web": "pnpm --filter @repo/db push:web",
    "db:push:realtime": "pnpm --filter @repo/db push:realtime",
    "db:push": "pnpm --filter @repo/db push",
    "db:migrate:web": "pnpm --filter @repo/db migrate:web",
    "db:migrate:realtime": "pnpm --filter @repo/db migrate:realtime",
    "db:migrate": "pnpm db:migrate:web && pnpm db:migrate:realtime",
    "db:generate:web": "pnpm --filter @repo/db generate:web",
    "db:generate:realtime": "pnpm --filter @repo/db generate:realtime",
    "db:generate": "pnpm db:generate:web && pnpm db:generate:realtime",
    "dev": "turbo run dev",
    "env:google-sa": "tsx scripts/env-google-service-account.ts --path",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
