# Environment file template for production
# Copy to .env.production and fill in actual values
# Change log: redacted committed secrets and aligned env names with the current workspace configuration.

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/helper_platform"
DATABASE_URL_WEB="postgresql://user:password@localhost:5432/helper_platform_web"
DATABASE_URL_REALTIME="postgresql://user:password@localhost:5432/helper_platform_realtime"

# Redis Configuration
